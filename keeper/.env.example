# Decant keeper + indexer configuration.

# RPC + chain. Defaults to public Base Sepolia.
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Markets to watch: "KEY:address" comma-separated. Defaults to the live Base Sepolia
# ETH/BTC/SOL markets when unset.
# MARKETS=ETH:0xB92951edfeC55296D593be9EA3858337cBc199cc,BTC:0x1D482BcEfe1a4ECBa59662b76D1265DfCa2A94b1,SOL:0xFb9a9df405Ffd8BAa9dAd9CC02946CDEFb2e34a7

# First block to backfill events from (the markets' deploy block on Base Sepolia).
START_BLOCK=42326000

# Private key the keeper uses to send liquidate()/settleFunding() txs.
# Leave unset to run in indexer + dry-run mode (logs liquidatable positions but sends no txs).
# KEEPER_PRIVATE_KEY=0x...

# SQLite file for the indexed events.
DB_PATH=./decant-indexer.sqlite

# Read API port.
API_PORT=8787

# Loop cadences (ms).
POLL_INTERVAL_MS=15000
FUNDING_INTERVAL_MS=3600000

# getLogs block range per request during backfill (public Base RPC caps this at 2000).
LOG_CHUNK=2000
